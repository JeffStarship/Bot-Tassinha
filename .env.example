# Telegram
TELEGRAM_BOT_TOKEN=
# IDs separados por vírgula, sem espaço. Pegue o seu e o da Tassinha no @userinfobot
TELEGRAM_ALLOWED_USER_IDS=

# Gemini (Google AI Studio - aistudio.google.com)
GEMINI_API_KEY=

# Supabase
SUPABASE_URL=
# Use a secret key (sb_secret_...), não a publishable
SUPABASE_SECRET_KEY=

# Configuração do negócio
TIMEZONE=America/Sao_Paulo
DEFAULT_RETURN_DAYS=21
AT_RISK_MULTIPLIER=1.3
BOT_NAME=Assistente
