# Telegram
TELEGRAM_BOT_TOKEN=
# IDs separados por vírgula, sem espaço. Pegue o seu e o da Tassinha no @userinfobot
TELEGRAM_ALLOWED_USER_IDS=

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
# Use a secret key (sb_secret_...), não a publishable
SUPABASE_SECRET_KEY=

# Modelos
MODELO_HAIKU=claude-haiku-4-5
MODELO_SONNET=claude-sonnet-4-6

# Configuração do negócio
TIMEZONE=America/Sao_Paulo
DEFAULT_RETURN_DAYS=21
AT_RISK_MULTIPLIER=1.3
BOT_NAME=Assistente
